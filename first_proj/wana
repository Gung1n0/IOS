#logs=("${init_arr[@]}")
temp_arr=()

    if (( ${filter_array[0]} == 0 )); then
    for log in "${logs[@]}"; do
        time="${log#*[}"
        time="${time%%]*}"
        if filter_a "${filter_argument[0]}" "$time"; then
            temp_arr+=("$log")
        fi
    done
    logs=("${temp_arr[@]}")
    temp_arr=()
fi

if (( ${filter_array[1]} == 0 )); then
    for log in "${logs[@]}"; do
        time="${log#*[}"
        time="${time%%]*}"
        if filter_b "${filter_argument[1]}" "$time"; then
            temp_arr+=("$log")
        fi
    done
    logs=("${temp_arr[@]}")
    temp_arr=()
fi

if (( ${filter_array[2]} == 0 )); then
    #filter pre ip
    for log in "${logs[@]}"; do
            ip_adr="${log%% *}"
            if filter_ip "${filter_argument[2]}" "$ip_adr"; then
                temp_arr+=("$log")
            fi
    done
    logs=("${temp_arr[@]}")
    temp_arr=()
fi

if (( ${filter_array[3]} == 0 )); then
    #filter pre uri
    for log in "${logs[@]}"; do
            uri=$(echo "$log" | awk '{print $7}')
            if filter_uri "$uri" "${filter_argument[3]}"; then
                temp_arr+=("$log")
            fi
    done
    logs=("${temp_arr[@]}")
    temp_arr=()
fi

#echo "$funct"

case "$funct" in
    list-ip)
        ip=()
        for log in "${logs[@]}"; do
            ip+=("${log%% *}")
        done
        find_unique "${ip[@]}"
        
        for arr in "${uq_arr[@]}"; do
            echo "$arr"
        done
        ;;
    list-hosts)
        ip=()
        for src in "${logs[@]}"; do
            ip+=("${src%% *}")
        done
        find_unique "${ip[@]}"
        find_hosts "${uq_arr[@]}"
        for arr in "${hosts[@]}"; do
            echo "$arr"
        done
    ;;
    list-uri)
       uri=()
        for log in "${logs[@]}"; do
            uri_temp=$(echo "$log" | awk '{print $7}')
            if [[ "${uri_temp:0:1}" == "/" ]]; then
             uri+=("$uri_temp")
            fi
        done
        find_unique "${uri[@]}"
        
        for arr in "${uq_arr[@]}"; do
            echo "$arr"
        done
        ;; 
    hist-ip)
    ip=()
    for log in "${logs[@]}"; do
        ip+=("${log%% *}")
    done
    find_unique "${ip[@]}"

    sorted=($(for ip_adrs in "${uq_arr[@]}"; do
    echo "${hist_count[$ip_adrs]} $ip_adrs"
    done | sort -rn | awk '{print $2}'))
    uq_arr=("${sorted[@]}")

    for ip in "${uq_arr[@]}"; do
    hash=""
    count=${hist_count[$ip]}
        for ((i=0; i < count; i++)); do
        hash+="#"
        done
        echo "$ip ($count): $hash"
    done
    ;;
    hist-load)
        ip=()
    for log in "${logs[@]}"; do
        time="${log#*[}"
        time="${time%%]*}"
        time="${time% *}"
        time=$(echo "$time" | sed 's/\// /g; s/:/ /')
        time=$(date -d "$time" "+%Y-%m-%d %H")
    ip+=("${time}:00")
    done
    find_unique "${ip[@]}"

    for ip in "${uq_arr[@]}"; do
    hash=""
        for ((i=0; i < ${hist_count[$ip]}; i++)); do
        hash+="#"
        done
        echo "$ip (${hist_count[$ip]}): $hash"
    done
    ;;
    *)
        if [[ -z "$funct" ]]; then
            for log in "${logs[@]}"; do
                echo "$log"
            done
        else
            echo "Incorrect Input" >&2
        fi
        ;;
esac