#!/bin/bash

GREEN='\033[0;32m'
RED='\033[0;31m'
NC='\033[0m' # No Color

pass=0
fail=0

run_test() {
    cmd="$1"
    expected_exit="$2"

    eval "$cmd" > /dev/null 2>&1
    actual_exit=$?

    if [ $actual_exit -eq $expected_exit ]; then
        echo -e "${GREEN}PASS: $cmd${NC}"
        ((pass++))
    else
        echo -e "${RED}FAIL: $cmd (expected $expected_exit, got $actual_exit)${NC}"
        ((fail++))
    fi
}

# valid
run_test "./main 1 2 4 1 1 1" 0
run_test "./main 1 2 4 1 1" 1
run_test "./main 1 2 4 1 1 1 1" 1

#min
run_test "./main 0 1 4 1 1 1" 1
run_test "./main 1 0 4 1 1 1" 1
run_test "./main 1 1 3 1 1 1" 1
run_test "./main 1 1 4 -1 1 1" 1
run_test "./main 1 1 4 1 -1 1" 1
run_test "./main 1 1 4 1 1 0" 1

#max
run_test "./main 11 1 4 1 1 1" 1
run_test "./main 1 10001 4 1 1 1" 1
run_test "./main 1 1 41 1 1 1" 1
run_test "./main 1 1 4 1001 1 1" 1
run_test "./main 1 1 4 1 1001 1" 1
run_test "./main 1 1 4 1 1 101" 1

echo ""
echo -e "Results: ${GREEN}$pass passed${NC}, ${RED}$fail failed${NC}"